generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Ticket {
  id            String    @id @default(uuid())
  subject       String
  customerName  String
  customerEmail String
  body          String
  status        String    @default("OPEN")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relation to AI analysis (1:1, optional)
  aiAnalysis    TicketAIAnalysis?

  @@index([status])
  @@index([createdAt])
}

model TicketAIAnalysis {
  id                String    @id @default(uuid())
  ticketId          String    @unique
  ticket            Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  aiTag             String
  aiPriority        String
  aiSuggestedReply  String
  aiProvider        String?
  aiModel           String?

  acceptedByAgent   Boolean?  // null = not decided yet, true/false = agent decision
  finalReply        String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([aiTag])
  @@index([aiPriority])
}

model AiConfig {
  id             Int      @id
  activeProvider String?
  openaiApiKey   String?
  geminiApiKey   String?
  kimiApiKey     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
